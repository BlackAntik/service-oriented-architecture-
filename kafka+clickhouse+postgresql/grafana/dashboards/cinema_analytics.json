    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
      "description": "Percentage of users from each cohort (by first view date) who returned on each subsequent day. Day 0 = 100% by definition.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "center",
            "cellOptions": { "type": "color-background", "mode": "gradient" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "rgba(50,50,200,0.05)", "value": null },
              { "color": "rgba(50,50,200,0.2)", "value": 10 },
              { "color": "rgba(50,50,200,0.4)", "value": 25 },
              { "color": "rgba(50,50,200,0.6)", "value": 50 },
              { "color": "rgba(50,50,200,0.8)", "value": 75 },
              { "color": "rgba(50,50,200,1.0)", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cohort_date" },
            "properties": [
              { "id": "displayName", "value": "Cohort" },
              { "id": "custom.width", "value": 120 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cohort_size" },
            "properties": [
              { "id": "displayName", "value": "Size" },
              { "id": "custom.width", "value": 70 },
              { "id": "unit", "value": "short" },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 25 },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Cohort" }]
      },
      "title": "Retention Cohort Heatmap (Day 0 to Day 7)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
          "rawSql": "WITH\n  cohorts AS (\n    SELECT\n      user_id,\n      toDate(min(event_time)) AS cohort_date\n    FROM default.movie_events\n    WHERE event_type = 'VIEW_STARTED'\n    GROUP BY user_id\n  ),\n  activity AS (\n    SELECT DISTINCT\n      user_id,\n      toDate(event_time) AS active_date\n    FROM default.movie_events\n    WHERE event_type = 'VIEW_STARTED'\n  )\nSELECT\n  toString(c.cohort_date) AS cohort_date,\n  count(DISTINCT c.user_id) AS cohort_size,\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date) / count(DISTINCT c.user_id), 1) AS \"Day 0\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 1) / count(DISTINCT c.user_id), 1) AS \"Day 1\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 2) / count(DISTINCT c.user_id), 1) AS \"Day 2\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 3) / count(DISTINCT c.user_id), 1) AS \"Day 3\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 4) / count(DISTINCT c.user_id), 1) AS \"Day 4\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 5) / count(DISTINCT c.user_id), 1) AS \"Day 5\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 6) / count(DISTINCT c.user_id), 1) AS \"Day 6\",\n  round(100.0 * countDistinctIf(c.user_id, a.active_date = c.cohort_date + 7) / count(DISTINCT c.user_id), 1) AS \"Day 7\"\nFROM cohorts c\nLEFT JOIN activity a ON c.user_id = a.user_id\nGROUP BY c.cohort_date\nORDER BY c.cohort_date DESC\nLIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    },
